# Local PostgreSQL Development Setup
# Before using this, make sure PostgreSQL is installed and running locally

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mocktest_dev
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/mocktest_dev

PORT=8080
NODE_ENV=development

JWT_SECRET=dev-secret-key-change-in-production

ADMIN_EMAIL=admin@test.com
ADMIN_PASSWORD=admin123
ADMIN_CODE=2010

ANSWER_SHEET_SECONDS=300

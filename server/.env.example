# Database Configuration
# For local PostgreSQL: postgresql://username:password@localhost:5432/mocktest
# For Neon (Vercel): postgresql://user:password@ep-xxx.region.neon.tech/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/mocktest
POSTGRES_URL=postgresql://user:password@localhost:5432/mocktest

# Server Configuration
PORT=8080
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production

# Admin Configuration
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-admin-password
ADMIN_CODE=2010

# File Upload
MAX_UPLOAD_BYTES=209715200

# Answer Sheet Timing
ANSWER_SHEET_SECONDS=300

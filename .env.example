# ---- Server ----
PORT=8080
NODE_ENV=production

# Secret used to sign session tokens. CHANGE THIS to a long random string.
JWT_SECRET=replace-with-a-long-random-secret

# ---- Database (Supabase Postgres) ----
# Your Supabase project: https://nymldzglxcuobgnjoyst.supabase.co
#
# IMPORTANT (especially on Vercel): use the CONNECTION POOLER string, NOT the
# direct connection (direct is IPv6-only and won't work on Vercel).
# Get it from: Supabase Dashboard -> Project Settings -> Database ->
#   "Connection string" -> Transaction pooler -> copy URI, then replace the
#   password. It looks like:
#   postgresql://postgres.nymldzglxcuobgnjoyst:YOUR_DB_PASSWORD@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.nymldzglxcuobgnjoyst:YOUR_DB_PASSWORD@aws-0-<region>.pooler.supabase.com:6543/postgres

# ---- Admin authentication ----
# The single Google account allowed to access the Admin Panel.
ADMIN_EMAIL=shohruxmuminov201@gmail.com

# Google OAuth Client ID (Web) — enables admin Google Sign-In.
# Leave empty to disable Google Sign-In.
GOOGLE_CLIENT_ID=

# Optional fallback: admin password login when Google OAuth is not configured.
ADMIN_PASSWORD=

# Simple admin access code for the Admin Panel (default 2010 if unset).
ADMIN_CODE=2010

# Max upload size in bytes (default 200 MB).
MAX_UPLOAD_BYTES=209715200

# ---- Server ----
PORT=8080
NODE_ENV=production

# Secret used to sign session tokens. CHANGE THIS to a long random string.
JWT_SECRET=replace-with-a-long-random-secret

# ---- Admin authentication ----
# The single Google account allowed to access the Admin Panel.
ADMIN_EMAIL=shohruxmuminov201@gmail.com

# Google OAuth Client ID (Web) used to verify Google Sign-In.
# Create one at https://console.cloud.google.com/apis/credentials
# Leave empty to disable Google Sign-In.
GOOGLE_CLIENT_ID=

# Optional fallback: lets the admin sign in with a password when Google OAuth
# is not configured. Leave empty to disable.
ADMIN_PASSWORD=

# ---- Storage ----
# Where the SQLite database lives (persist this directory in production).
DATA_DIR=./data
# Where uploaded HTML / audio / PDF files are stored (persist this too).
UPLOAD_DIR=./server/uploads

# Max upload size in bytes (default 200 MB).
MAX_UPLOAD_BYTES=209715200
